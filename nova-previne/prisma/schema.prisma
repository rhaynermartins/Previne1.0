generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HealthCheck {
  id        String   @id @default(cuid())
  status    String   @default("ok")
  metadata  Json?
  checkedAt DateTime @default(now())

  @@map("health_checks")
}
